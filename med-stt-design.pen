                      "type": "text",
                      "id": "dJr9W",
                      "fill": "#219EBC",
                      "content": "Plan",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "bold"
                    },
                    {
                      "type": "text",
                      "id": "R3Lan",
                      "fill": "#444444",
                      "content": "1. Start amlodipine 5mg daily\n2. Order stress echocardiogram\n3. Lipid panel, BMP labs\n4. Follow-up in 2 weeks\n5. Advise moderate exercise with monitoring",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                }
