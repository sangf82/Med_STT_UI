                  "type": "text",
                  "id": "m2p63",
                  "fill": "#219EBC",
                  "content": "Chủ quan",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "bold"
                },
                {
                  "type": "text",
                  "id": "T8Uz1",
                  "fill": "#444444",
                  "content": "Bệnh nhân còn đau tức ngực nhẹ tại\nvùng thượng vị, không lan. Không khó\nthở, không vã mồ hôi.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "4Ajbk",
