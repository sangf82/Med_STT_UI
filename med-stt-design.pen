                {
                  "type": "text",
                  "id": "LWCcU",
                  "fill": "#219EBC",
                  "content": "Subjective",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "bold"
                },
                {
                  "type": "text",
                  "id": "tOGEL",
                  "fill": "#444444",
                  "content": "Patient reports recurring episodes of\nchest tightness, primarily during\nphysical exertion for the past 3 weeks.\nDescribes the sensation as a squeezing\npressure lasting 5-10 minutes. Denies\nradiation to arms or jaw. Reports mild\ndyspnea on exertion.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "Ms16w",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 6,
              "children": [
                {
                  "type": "text",
                  "id": "NdL80",
                  "fill": "#219EBC",
                  "content": "Objective",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "bold"
                },
                {
                  "type": "text",
                  "id": "e86Et",
                  "fill": "#444444",
                  "content": "BP: 145/92 mmHg. HR: 82 bpm, regular.\nChest auscultation reveals normal S1,\nS2. No murmurs or gallops. Lungs clear\nbilateral. ECG: normal sinus rhythm,\nno ST changes.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "2v6G1",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 6,
              "children": [
                {
                  "type": "text",
                  "id": "vAWQx",
                  "fill": "#219EBC",
                  "content": "Assessment",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "bold"
                },
                {
                  "type": "text",
                  "id": "ufTjh",
                  "fill": "#444444",
                  "content": "Exertional chest tightness with elevated\nblood pressure. Differential includes\nstable angina, hypertension-related\nsymptoms. Low risk for acute coronary\nsyndrome.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "XrhBc",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 6,
              "children": [
                {
                  "type": "text",
                  "id": "7s3L9",
                  "fill": "#219EBC",
                  "content": "Plan",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "bold"
                },
                {
                  "type": "text",
                  "id": "FxjOl",
                  "fill": "#444444",
                  "content": "1. Start amlodipine 5mg daily\n2. Order stress echocardiogram\n3. Lipid panel, BMP labs\n4. Follow-up in 2 weeks\n5. Advise moderate exercise with monitoring",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
