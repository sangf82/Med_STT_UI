                    },
                    {
                      "type": "text",
                      "id": "PLywS",
                      "fill": "#444444",
                      "content": "Patient reports recurring episodes of\nchest tightness, primarily during\nphysical exertion for the past 3 weeks.\nDescribes the sensation as a squeezing\npressure lasting 5-10 minutes. Denies\nradiation to arms or jaw. Reports mild\ndyspnea on exertion.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "iDiLz",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 6,
                  "children": [
                    {
                      "type": "text",
                      "id": "d84eZ",
                      "fill": "#219EBC",
                      "content": "Objective",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "bold"
                    },
                    {
                      "type": "text",
                      "id": "7auq2",
                      "fill": "#444444",
                      "content": "BP: 145/92 mmHg. HR: 82 bpm, regular.\nChest auscultation reveals normal S1,\nS2. No murmurs or gallops. Lungs clear\nbilateral. ECG: normal sinus rhythm,\nno ST changes.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "7pKBH",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 6,
                  "children": [
