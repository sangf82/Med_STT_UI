                      "type": "text",
                      "id": "2gAN5",
                      "fill": "#219EBC",
                      "content": "Assessment",
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "bold"
                    },
                    {
                      "type": "text",
                      "id": "oedC5",
                      "fill": "#444444",
                      "content": "Exertional chest tightness with elevated\nblood pressure. Differential includes\nstable angina, hypertension-related\nsymptoms. Low risk for acute coronary\nsyndrome.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "0mUof",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 6,
                  "children": [
