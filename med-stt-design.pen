              ]
            },
            {
              "type": "frame",
              "id": "xSBmz",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 6,
              "children": [
                {
                  "type": "text",
                  "id": "93Zie",
                  "fill": "#219EBC",
                  "content": "Subjective",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "bold"
                },
                {
                  "type": "text",
                  "id": "ztfRf",
                  "fill": "#CCCCCC",
                  "content": "Patient reports recurring episodes of\nchest tightness, primarily during\nphysical exertion for the past 3 weeks.\nDescribes the sensation as a squeezing\npressure lasting 5-10 minutes. Denies\nradiation to arms or jaw. Reports mild\ndyspnea on exertion.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "rmtMv",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 6,
              "children": [
                {
                  "type": "text",
                  "id": "5nzVn",
                  "fill": "#219EBC",
                  "content": "Objective",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "bold"
                },
                {
                  "type": "text",
                  "id": "3ijSL",
                  "fill": "#CCCCCC",
                  "content": "BP: 145/92 mmHg. HR: 82 bpm, regular.\nChest auscultation reveals normal S1,\nS2. No murmurs or gallops. Lungs clear\nbilateral. ECG: normal sinus rhythm,\nno ST changes.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "Lwq0N",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 6,
              "children": [
                {
                  "type": "text",
                  "id": "s2Glj",
                  "fill": "#219EBC",
                  "content": "Assessment",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "bold"
                },
                {
                  "type": "text",
                  "id": "Q2oZZ",
                  "fill": "#CCCCCC",
                  "content": "Exertional chest tightness with elevated\nblood pressure. Differential includes\nstable angina, hypertension-related\nsymptoms. Low risk for acute coronary\nsyndrome.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            },
            {
              "type": "frame",
              "id": "Jbgog",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 6,
              "children": [
                {
                  "type": "text",
                  "id": "Zm2oV",
                  "fill": "#219EBC",
                  "content": "Plan",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "bold"
                },
                {
                  "type": "text",
                  "id": "8XFUF",
                  "fill": "#CCCCCC",
                  "content": "1. Start amlodipine 5mg daily\n2. Order stress echocardiogram\n3. Lipid panel, BMP labs\n4. Follow-up in 2 weeks\n5. Advise moderate exercise with monitoring",
                  "lineHeight": 1.6,
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
        },
